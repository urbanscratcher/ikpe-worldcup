{
  "name": "ikpe-worldcup",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint .",
    "format": "oxc format --write .",
    "check": "pnpm typecheck && pnpm lint"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.7.0",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "oxc": "^1.0.1",
    "oxlint": "^1.72.0",
    "turbo": "^2.10.3",
    "typescript": "^5.9.2"
  }
}
